<apex:page Controller="Loan">
    <apex:form >
        <apex:pageBlock >
            <h1 style="color:red;text-align:center;padding-left:600px;margin-buttom:500px;">
                Loan Calculator
            </h1> <br/>
            <h1 style="border-width:2px; border-style:solid; border-color:black; padding:10px; width:200px;">
                Annual Interest
            </h1>
            
            <apex:inputText value="{!AnnualInterest}" title="Amount" style="margin:10px;border-style:solid;border-width:2px;padding:9px;" />
            <br/> 
           <h1 style="border-width:2px; border-style:solid; border-color:black; padding:10px;width:200px">
                Year
            </h1>
            
            <apex:inputText value="{!Years}" title="Amount" style="margin:10px;border-style:solid;border-width:2px;padding:9px;"/><br/>
           <h1 style="border-width:2px; border-style:solid; border-color:black; padding:10px;width:200px"> 	
                Amount
            </h1>
            <apex:inputText value="{!Amount}" title="Amount" style="margin:10px;border-style:solid;border-width:2px;padding:9px;"/><br/>
            <apex:commandButton value="Compute" action="{!GetInterest}"/>
            <br/>
            Monthly Payment:<apex:inputText value="{!MonthlyPayment}" style="margin:10px" />
            Total Payment:<apex:inputText value="{!TotalPayment}" style="margin:10px"/>
        </apex:pageBlock>
    </apex:form>
</apex:page>